---
const {
  title = '个人博客',
  description = '一个用 Astro 和 Cloudflare Pages 托管的个人博客。'
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Algustav</a>
      <nav aria-label="主导航">
        <a href="/">首页</a>
        <a href="/blog/">文章</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© {new Date().getFullYear()} Algustav</span>
      <span>Built with Astro</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f2e8;
    --paper: #fffaf0;
    --ink: #1c1a17;
    --muted: #70695f;
    --line: #d8cdbd;
    --accent: #0b6b62;
    --accent-strong: #d1492e;
    --shadow: 0 18px 50px rgba(28, 26, 23, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      linear-gradient(90deg, rgba(11, 107, 98, 0.07) 1px, transparent 1px),
      linear-gradient(rgba(11, 107, 98, 0.06) 1px, transparent 1px),
      var(--bg);
    background-size: 32px 32px;
    color: var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    line-height: 1.65;
  }

  a {
    color: inherit;
  }

  .site-header,
  .site-footer {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .site-header {
    padding: 28px 0 20px;
  }

  .brand {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 18px;
    color: var(--muted);
    font-size: 0.96rem;
  }

  nav a {
    text-decoration: none;
  }

  nav a:hover {
    color: var(--accent);
  }

  main {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero {
    min-height: 52vh;
    display: grid;
    align-items: center;
    padding: 64px 0 48px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .hero-inner {
    max-width: 860px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.92;
    letter-spacing: 0;
  }

  .hero p {
    max-width: 640px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 1.16rem;
  }

  .section-title {
    margin: 64px 0 22px;
    font-size: 1rem;
    color: var(--muted);
    text-transform: uppercase;
  }

  .post-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-bottom: 56px;
  }

  .post-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }

  .post-card a {
    display: block;
    min-height: 230px;
    padding: 28px;
    text-decoration: none;
  }

  .post-card span {
    color: var(--accent);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .post-card h2 {
    margin: 18px 0 10px;
    font-size: 1.8rem;
    line-height: 1.05;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
  }

  .post-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .post-card li {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 3px 10px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .article {
    max-width: 760px;
    margin: 48px auto 80px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: clamp(28px, 6vw, 64px);
    box-shadow: var(--shadow);
  }

  .article time {
    color: var(--accent);
    font-weight: 700;
  }

  .article h1 {
    margin: 14px 0 20px;
    font-size: clamp(2.4rem, 7vw, 4.8rem);
  }

  .article-description {
    color: var(--muted);
    font-size: 1.15rem;
  }

  .article-content {
    margin-top: 42px;
    font-size: 1.08rem;
  }

  .article-content h2 {
    margin-top: 2.1em;
    font-size: 1.7rem;
    line-height: 1.15;
  }

  .article-content code {
    background: #eee2d1;
    border-radius: 4px;
    padding: 2px 5px;
    font-size: 0.92em;
  }

  .article-content pre {
    overflow-x: auto;
    background: #1c1a17;
    color: #fffaf0;
    border-radius: 8px;
    padding: 18px;
  }

  .site-footer {
    padding: 32px 0 44px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
  }

  @media (max-width: 720px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      width: 100%;
      justify-content: space-between;
    }

    .hero {
      min-height: auto;
      padding: 48px 0 40px;
    }

    .post-list {
      grid-template-columns: 1fr;
    }
  }
</style>
